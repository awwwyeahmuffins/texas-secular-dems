---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";

const events = (await getCollection("events")).sort((a, b) => {
  const ad = a.data.sortDate?.getTime() ?? 0;
  const bd = b.data.sortDate?.getTime() ?? 0;
  return bd - ad; // newest first
});
const upcoming = events.filter((e) => e.data.upcoming);
const past = events.filter((e) => !e.data.upcoming);
---

<BaseLayout title="Events" description="Caucus meetings, socials, elections, and actions from the Secular Democrats of Texas.">
  <section class="section">
    <div class="container">
      <header class="section__head">
        <p class="eyebrow">Calendar</p>
        <h1>Events</h1>
        <p>Caucus meetings, socials, elections, and actions. Want to host or co-sponsor an event? <a href={site.contactFormUrl} target="_blank" rel="noopener">Get in touch.</a></p>
      </header>

      {upcoming.length > 0 && (
        <>
          <h2>Upcoming</h2>
          <div class="events">
            {await Promise.all(upcoming.map(async (e) => {
              const { Content } = await render(e);
              return (
                <article class="event">
                  <div class="event__date">{e.data.date}</div>
                  <div class="event__body">
                    <h3>{e.data.title}</h3>
                    {e.data.location && <p class="event__loc">📍 {e.data.location}</p>}
                    <div class="event__desc"><Content /></div>
                  </div>
                </article>
              );
            }))}
          </div>
        </>
      )}

      <h2 style={upcoming.length ? "margin-top:3rem;" : ""}>Past events</h2>
      <div class="events">
        {await Promise.all(past.map(async (e) => {
          const { Content } = await render(e);
          return (
            <article class="event">
              <div class="event__date">{e.data.date}</div>
              <div class="event__body">
                <h3>{e.data.title}</h3>
                {e.data.location && <p class="event__loc">📍 {e.data.location}</p>}
                <div class="event__desc"><Content /></div>
              </div>
            </article>
          );
        }))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .events {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 820px;
  }
  .event {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-left: 4px solid var(--blue);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow);
  }
  .event__date {
    font-weight: 700;
    color: var(--navy);
    font-family: var(--font-head);
  }
  .event__body h3 {
    margin-bottom: 0.25rem;
  }
  .event__loc {
    color: var(--gray-500);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .event__desc :global(p:last-child) {
    margin-bottom: 0;
  }
  @media (max-width: 640px) {
    .event {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
