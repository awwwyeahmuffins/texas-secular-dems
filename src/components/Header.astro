---
import site from "../data/site.json";
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <span class="brand__star" aria-hidden="true">★</span>
      <span class="brand__name">Secular Democrats<br /><span>of Texas</span></span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      <a href="/" class:list={["site-nav__link", { active: pathname === "/" }]}>Home</a>

      <div class="site-nav__group">
        <a href="/about/" class:list={["site-nav__link", { active: isActive("/about") }]}>
          About <span class="caret" aria-hidden="true">▾</span>
        </a>
        <div class="site-nav__menu">
          <a href="/about/">Overview</a>
          <a href="/about/statistics/">Statistics on Secular Americans</a>
          <a href="/about/why-a-secular-caucus/">Why We Need a Secular Caucus</a>
          <a href="/about/by-laws/">By-Laws</a>
        </div>
      </div>

      <a href="/successes/" class:list={["site-nav__link", { active: isActive("/successes") }]}>Successes</a>
      <a href="/events/" class:list={["site-nav__link", { active: isActive("/events") }]}>Events</a>
      <a href="/endorsements/" class:list={["site-nav__link", { active: isActive("/endorsements") }]}>Endorsements</a>
      <a href="/contact/" class:list={["site-nav__link", { active: isActive("/contact") }]}>Contact</a>

      <a href={site.donateUrl} class="btn btn--donate site-nav__donate" target="_blank" rel="noopener">Donate</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--white);
    border-bottom: 1px solid var(--gray-200);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 72px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--navy);
  }
  .brand__star {
    color: var(--red);
    font-size: 1.6rem;
    line-height: 1;
  }
  .brand__name {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 1.05rem;
    line-height: 1.05;
    color: var(--navy);
  }
  .brand__name span {
    font-weight: 600;
    color: var(--blue);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .site-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.5rem 0.7rem;
    border-radius: 8px;
    color: var(--gray-700);
    font-weight: 600;
    font-size: 0.97rem;
    white-space: nowrap;
  }
  .site-nav__link:hover {
    color: var(--navy);
    background: var(--gray-50);
    text-decoration: none;
  }
  .site-nav__link.active {
    color: var(--blue);
  }
  .caret {
    font-size: 0.7rem;
  }

  .site-nav__group {
    position: relative;
  }
  .site-nav__menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 0.4rem;
    min-width: 250px;
    display: none;
    flex-direction: column;
  }
  .site-nav__group:hover .site-nav__menu,
  .site-nav__group:focus-within .site-nav__menu {
    display: flex;
  }
  .site-nav__menu a {
    padding: 0.5rem 0.7rem;
    border-radius: 8px;
    color: var(--gray-700);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .site-nav__menu a:hover {
    background: var(--gray-50);
    color: var(--navy);
    text-decoration: none;
  }
  .site-nav__donate {
    margin-left: 0.5rem;
    padding: 0.55rem 1.1rem;
  }

  /* Mobile */
  .nav-toggle,
  .nav-burger {
    display: none;
  }
  @media (max-width: 920px) {
    .nav-burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      cursor: pointer;
      padding: 10px;
    }
    .nav-burger span {
      height: 2px;
      background: var(--navy);
      border-radius: 2px;
    }
    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid var(--gray-200);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem 1.25rem 1.25rem;
      display: none;
      box-shadow: var(--shadow);
    }
    .nav-toggle:checked ~ .site-nav {
      display: flex;
    }
    .site-nav__group {
      display: flex;
      flex-direction: column;
    }
    .site-nav__menu {
      position: static;
      display: flex;
      border: none;
      box-shadow: none;
      padding: 0 0 0 1rem;
      min-width: 0;
    }
    .caret {
      display: none;
    }
    .site-nav__donate {
      margin: 0.75rem 0 0;
      text-align: center;
    }
  }
</style>
